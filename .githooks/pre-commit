#!/bin/sh
if [ -f "vendor/bin/grumphp" ]; then
    exec vendor/bin/grumphp run --config grumphp.yml
elif [ -f "../../vendor/bin/grumphp" ]; then
    exec ../../vendor/bin/grumphp run --config grumphp.yml
else
    echo "GrumPHP not found. Run composer install in your Magento playground or module directory."
    exit 1
fi
