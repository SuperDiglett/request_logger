{
    "name": "sd/request_logger",
    "version": "0.0.1",
    "description": "Magento 2 module to log API request/response payloads for debugging purposes.",
    "type": "magento2-module",
    "license": "MIT",
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Sd\\RequestLogger\\": ""
        }
    },
    "authors": [
        {
            "name": "Kevin van Hengst"
        }
    ],
    "require": {
        "magento/framework": "^101.0.1|^101.1|^102.0|^103.0"
    },
    "require-dev": {
        "bitexpert/phpstan-magento": "^0.42.0",
        "magento/magento-coding-standard": "^40.0",
        "phpro/grumphp-shim": "^2.19"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpro/grumphp-shim": true
        }
    }
}
